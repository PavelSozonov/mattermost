# Managed by Ansible — local edits will be overwritten on the next deploy.
COMPOSE_PROJECT_NAME=mattermost

MATTERMOST_IMAGE={{ mattermost_image }}
MATTERMOST_IMAGE_TAG={{ mattermost_image_tag }}
POSTGRES_IMAGE_TAG={{ mattermost_postgres_image_tag }}
CADDY_IMAGE_TAG={{ mattermost_caddy_image_tag }}

POSTGRES_USER={{ mattermost_postgres_user }}
POSTGRES_PASSWORD={{ mattermost_postgres_password }}
